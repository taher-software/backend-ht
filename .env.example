# Database Configuration
db_url=postgresql://user:password@localhost:5432/bodor

# JWT Configuration
jwt_secret=your-secret-key-here
jwt_algorithm=HS256
jwt_access_expires=3600

# Email Configuration (for sending admin notifications)
mail_username=your-email@gmail.com
mail_pwd=your-app-password

# Application URL
application_url=http://localhost:8200

# OpenAI API Key (for generating notification content)
openia_apikey=sk-your-openai-api-key

# Google Cloud Project ID (optional - auto-detected from service account if not set)
# Used by Cloud Tasks, Pub/Sub, Firestore, and Cloud Storage
# gcp_project_id=your-gcp-project-id

# Worker URL for Cloud Tasks (base URL without endpoint suffix)
# This is the public URL where Cloud Tasks will send HTTP requests
worker_url=https://your-app-domain.com/worker

# Firestore Configuration
# Firestore uses the same project_id as other GCP services (auto-detected)
# Default database ID is "(default)" - no configuration needed unless using custom database
# Ensure your service account has Firestore permissions:
# - Cloud Datastore User (for read/write access)
# - Or custom role with datastore.* permissions

# Super Admin Emails (REQUIRED for job failure alerts)
# Comma-separated list of email addresses
super_admin_emails=admin1@bodor.com,admin2@bodor.com,devops@bodor.com

# Commercial Team Emails (REQUIRED for account review notifications)
# Comma-separated list of email addresses for suspicious account alerts
commercial_emails=commercial1@bodor.com,commercial2@bodor.com,sales@bodor.com

# Mobile App Configuration
# App names and store URLs for account confirmation emails
app_store_app_name=Bodor Hotel Manager
play_store_app_name=Bodor Hotel Manager
app_store_url=https://apps.apple.com/app/bodor-hotel-manager/id123456789
play_store_url=https://play.google.com/store/apps/details?id=com.bodor.hotel
